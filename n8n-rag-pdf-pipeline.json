    {
      "parameters": {
        "jsCode": "const item = $input.first();\nlet text = item.json.extracted_text || \"\";\n\n// normalisation basique\ntext = text\n  .replace(/\\r/g, \"\\n\")\n  .replace(/\\t/g, \" \")\n  .replace(/\\u0000/g, \" \")\n  .replace(/[ ]{2,}/g, \" \")\n  .replace(/\\n{3,}/g, \"\\n\\n\")\n  .trim();\n\n// fusion légère des lignes cassées\ntext = text\n  .split(\"\\n\")\n  .map(line => line.trim())\n  .filter(line => line.length > 0)\n  .join(\"\\n\");\n\nreturn [\n  {\n    json: {\n      ...item.json,\n      clean_text: text\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1024,
        388
      ],
      "id": "69613c53-645e-4f32-8ff4-d17df8df3cb3",
      "name": "Code - Nettoyer texte extrait"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst text = item.json.clean_text || \"\";\nconst chunkSize = 1200;   // taille approximative en caractères\nconst overlap = 200;      // recouvrement entre chunks\n\nif (!text.trim()) {\n  return [];\n}\n\nconst chunks = [];\nlet start = 0;\nlet index = 0;\n\nwhile (start < text.length) {\n  let end = start + chunkSize;\n\n  if (end < text.length) {\n    const lastSpace = text.lastIndexOf(\" \", end);\n    if (lastSpace > start + 200) {\n      end = lastSpace;\n    }\n  }\n\n  const chunkText = text.slice(start, end).trim();\n\n  if (chunkText) {\n    chunks.push({\n      json: {\n        job_id: item.json.job_id,\n        tenant_id: item.json.tenant_id,\n        filename: item.json.filename,\n        storage_key: item.json.storage_key,\n        chunk_index: index,\n        chunk_text: chunkText\n      }\n    });\n    index++;\n  }\n\n  start = Math.max(end - overlap, end);\n}\n\nreturn chunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1248,
        388
      ],
      "id": "924f73d3-8ad8-49ec-9f72-94a686445ee4",
      "name": "Code - Découper en chunk"
    },
